# LLM configuration
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1-mini
LLM_API_KEY=sk-your-key-here

# For Ollama (local/offline):
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen2.5:14b
# LLM_API_KEY=

# Server
PORT=3001

# Voice
# STT_BASE_URL=https://api.openai.com/v1
# STT_MODEL=whisper-1
# TTS_BASE_URL=https://api.openai.com/v1
# TTS_MODEL=gpt-4o-mini-tts
# TTS_VOICE=shimmer                  # shimmer | coral | sage (curated) — other OpenAI voices also valid
# TTS_SPEED=1.0                      # 0.5–1.5 (clamped). UI exposes 0.85 / 1.0 / 1.15
# TTS_INSTRUCTIONS=Sprich ruhig, wertschätzend, mit kurzen Pausen nach Fragen. Warmer Ton.
